        while state.alive do
            if not getHRP() then task.wait(0.1); continue end
            if raidBoss=="Jotaro" then doJotaroTP() else doAvdolTP() end; task.wait(15)
        end; return
    end
    local tpFn=raidBoss=="Jotaro" and doJotaroTP or doAvdolTP
    lobbyLoop(state,tpFn,startAnubisRaidFight)
end

local function startAvdolVoid(state)
    if game.PlaceId==RAID_PLACE_ID then
        while state.alive do
            if not getHRP() then task.wait(0.1); continue end
            if voidBoss=="Jotaro" then doJotaroTP() else doAvdolTP() end; task.wait(15)
        end; return
    end
    local tpFn=voidBoss=="Jotaro" and doJotaroTP or doAvdolTP
    local fightFn=voidMethod=="Killer Queen" and startKQVoidFight or startVampireVoidFight
    lobbyLoop(state,tpFn,fightFn)
end

local function autoRetryFarm(state)
    while state.alive do
        pcall(function()
            local pg=player:FindFirstChild("PlayerGui"); if not pg then return end
            local rc=pg:FindFirstChild("raidcomplete"); if not rc then return end
            local btn=rc.raid.retry.TextButton
            local abs=btn.AbsolutePosition; local sz=btn.AbsoluteSize
            local x=abs.X+sz.X/2; local y=abs.Y+sz.Y/2
            mousemoveabs(x,y); task.wait(0.2)
            for i=1,25 do mousemoveabs(x+i,y); task.wait(0.01) end
            task.wait(0.1); mouse1press(); task.wait(0.1); mouse1release(); task.wait(1)
        end)
        task.wait(0.5)
    end
end

