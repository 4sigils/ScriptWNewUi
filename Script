local function findAvdolNPC()
    for _, obj in liveFolder:GetChildren() do
        if obj.Name=="Server" then continue end
        if not obj:IsA("Model") then continue end
        if playerNames[obj.Name] then continue end
        if obj.Name:sub(1,15)~=".Muhammad Avdol" then continue end
        if not obj:FindFirstChild("HumanoidRootPart") then continue end
        local hum=obj:FindFirstChildWhichIsA("Humanoid")
        if not hum or hum.Health<=0 then continue end
        return obj
    end
    return nil
end

local function clickQuickPlay()
    local playerGui=player:WaitForChild("PlayerGui")
    local mainMenu=playerGui:FindFirstChild("Main Menu"); if not mainMenu then return end
    local buttons=mainMenu:WaitForChild("Buttons",5)
    local qp=buttons and buttons:WaitForChild("Quick Play",5); if not qp then return end
    task.wait(0.5)
    pcall(function()
        local abs=qp.AbsolutePosition; local sz=qp.AbsoluteSize
        local x=abs.X+sz.X/2+50; local y=abs.Y+sz.Y/2
        mousemoveabs(x,y); task.wait(0.2)
        for i=1,25 do mousemoveabs(x+i,y); task.wait(0.01) end
        task.wait(0.1); mouse1press(); task.wait(0.1); mouse1release()
    end)
    task.wait(3)
end

local function startAnubisRaidFight(state)
    local SAFE=Vector3.new(786,1016,-8)
    local keys={0x52,0x5A,0x58,0x43}
    clickQuickPlay()
    local hrp=getHRP(); if hrp then pcall(function() hrp.Position=SAFE; hrp.AssemblyLinearVelocity=Vector3.new(0,0,0) end) end
    task.wait(0.5); pressTabUntilStandSummoned()
    while state.alive do
        local avdol=findAvdolNPC()
        if not avdol then
            hrp=getHRP(); if hrp then pcall(function() hrp.Position=SAFE; hrp.AssemblyLinearVelocity=Vector3.new(0,0,0) end) end
            task.wait(1); continue
        end
        local aHRP=avdol:FindFirstChild("HumanoidRootPart"); if not aHRP then task.wait(0.5); continue end
        hrp=getHRP(); if hrp then pcall(function() hrp.Position=aHRP.Position; hrp.AssemblyLinearVelocity=Vector3.new(0,0,0) end) end
        for _,key in ipairs(keys) do
            if not state.alive then break end
            pcall(keypress,key); task.wait(0.1); pcall(keyrelease,key); task.wait(0.25)
            avdol=findAvdolNPC(); aHRP=avdol and avdol:FindFirstChild("HumanoidRootPart")
            if aHRP then hrp=getHRP(); if hrp then pcall(function() hrp.Position=aHRP.Position; hrp.AssemblyLinearVelocity=Vector3.new(0,0,0) end) end end
            task.wait(1)
            hrp=getHRP(); if hrp then pcall(function() hrp.Position=SAFE; hrp.AssemblyLinearVelocity=Vector3.new(0,0,0) end) end
            task.wait(1.5)
        end
        task.wait(10)
    end
end

